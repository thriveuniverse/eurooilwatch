# Copy this file to .env.local and fill in the values.
# Never commit .env.local to git.

# Resend — email subscription & newsletter sending
# Get API key from: https://resend.com/api-keys
# Run `npm run setup:resend` once to generate RESEND_SEGMENT_ID and RESEND_TOPIC_ID
RESEND_API_KEY=
RESEND_SEGMENT_ID=
RESEND_TOPIC_ID=

# Resend — sending address (must match a domain verified in your Resend account)
# Format: Display Name <email@yourdomain.com>
RESEND_FROM_ADDRESS=

# Anthropic — AI analysis generation (needed for: npm run analyze)
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# AISStream — live tanker map (optional, map falls back gracefully without it)
# Get from: https://aisstream.io
NEXT_PUBLIC_AISSTREAM_API_KEY=

# NASA FIRMS — thermal anomaly detection near refineries (optional, panel shows setup prompt without it)
# Register free (email only, no OAuth) at: https://firms.modaps.eosdis.nasa.gov/api/area/
FIRMS_MAP_KEY=
