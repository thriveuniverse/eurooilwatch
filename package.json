{
  "name": "eurooilwatch",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "fetch:stocks": "npx tsx scripts/fetch-eurostat-stocks.ts",
    "fetch:prices": "npx tsx scripts/fetch-oil-bulletin.ts",
    "fetch:brent": "npx tsx scripts/fetch-brent.ts",
    "fetch:all": "npm run fetch:stocks && npm run fetch:prices && npm run fetch:brent",
    "analyze": "npx tsx scripts/generate-analysis.ts",
    "update": "npm run fetch:all && npm run analyze",
    "test:api": "npx tsx scripts/test-eurostat-api.ts"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "next": "14.2.21",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.12.7",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.4",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4"
  }
}
